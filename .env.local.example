# ══ COPY THIS TO .env.local AND FILL IN YOUR VALUES ══
# NEVER commit .env.local to git

# n8n Webhook URLs (your self-hosted instance)
N8N_WEBHOOK_ONBOARD=https://bryantechautomation.seltechai.com/webhook/onboard
N8N_WEBHOOK_CHAT=https://bryantechautomation.seltechai.com/webhook/chat
N8N_WEBHOOK_DEMO=https://bryantechautomation.seltechai.com/webhook/demo
N8N_WEBHOOK_CALENDAR=https://bryantechautomation.seltechai.com/webhook/calendar

# Also set these as n8n Variables in your n8n instance:
# Settings → Variables → Add Variable

# FIRECRAWL_API_KEY      → get from firecrawl.dev (free tier available)
# ANTHROPIC_API_KEY      → get from console.anthropic.com
# SUPABASE_URL           → e.g. https://abcxyz.supabase.co
# SUPABASE_ANON_KEY      → from Supabase project Settings → API
# ELEVENLABS_API_KEY     → get from elevenlabs.io
# GHL_API_KEY            → from GHL Settings → API Keys
# GHL_LOCATION_ID        → from GHL Settings → Business Profile
# N8N_BASE_URL           → https://bryantechautomation.seltechai.com
